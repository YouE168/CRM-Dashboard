# ============================================
# 🔐 SECURITY - NEVER COMMIT THESE!
# ============================================

# Environment variables (CRITICAL!)
.env
.env*.local
.env.*
.env.production
.env.development
.env.test
.env.staging

# API keys and secrets
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
secrets.ts
api-keys.ts
credentials.ts
auth-config.ts
*secret*.ts
*key*.ts

# Authentication files
.htpasswd
.htaccess
oauth.json
firebase-*.json
service-account*.json

# ============================================
# 📦 DEPENDENCIES
# ============================================

node_modules/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.pnp/
.pnp.js
.pnp.loader.mjs

# ============================================
