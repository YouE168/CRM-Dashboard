docker-compose.override.yml
*.dockerignore

# Vercel (already in .next)
.vercel/

# ============================================
# ✅ EXCEPTIONS - Files you SHOULD commit
# ============================================

!.gitignore
!.env.example
!README.md
!LICENSE
!package.json
!next.config.js
!tailwind.config.js
!postcss.config.js
!components.json
!tsconfig.json
!public/**/*
!styles/**/*

# ============================================
# 🎯 V0/SANDBOX FILES
# ============================================

__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
next.user-config.*
